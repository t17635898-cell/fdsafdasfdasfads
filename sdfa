        for _, obj in pairs(ESPObjects) do
            obj.Box.Visible = false
            obj.Text.Visible = false
            obj.Line.Visible = false
        end
    else
        local camera = Workspace.CurrentCamera
        local viewportSize = camera.ViewportSize
        local myRoot = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        local myPos = myRoot and myRoot.Position

        for player, obj in pairs(ESPObjects) do
            local validESP = false
            local validLine = false

            if player ~= LP and player.Character then
                local hum = player.Character:FindFirstChild("Humanoid")
                local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                
                if hum and hrp and hum.Health > 0 then
                    local pos, onScreen = camera:WorldToViewportPoint(hrp.Position)
                    
                    if Toggles.ESP.Value and onScreen then
                        local headPos = camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3, 0))
                        local legPos = camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
                        local height = math.abs(headPos.Y - legPos.Y)
                        local width = height / 2

                        obj.Box.Size = Vector2.new(width, height)
                        obj.Box.Position = Vector2.new(pos.X - width/2, pos.Y - height/2)
                        obj.Box.Color = Color3.new(1, 0, 0)
                        obj.Box.Visible = true

                        obj.Text.Text = player.Name .. " (" .. math.floor(hum.Health) .. " HP)"
                        obj.Text.Position = Vector2.new(pos.X, pos.Y - height/2 - 15)
                        obj.Text.Color = Color3.new(1, 1, 1)
                        obj.Text.Visible = true
                        validESP = true
                    end

                    if Toggles.LineESP.Value and myPos then
                        local screenPos, lineOnScreen = camera:WorldToViewportPoint(hrp.Position)
                        if lineOnScreen then
                            obj.Line.From = Vector2.new(viewportSize.X/2, viewportSize.Y/2)
                            obj.Line.To = Vector2.new(screenPos.X, screenPos.Y)
                            obj.Line.Color = Color3.new(0, 1, 0)
                            obj.Line.Visible = true
                            validLine = true
                        end
                    end
                end
            end

            if not validESP then
                obj.Box.Visible = false
                obj.Text.Visible = false
            end
            if not validLine then
                obj.Line.Visible = false
            end
        end
    end

    -- Health ESP (Hearts) 처리 (아군 가리지 않고 모두 표시)
    if Toggles.HealthESP and Toggles.HealthESP.Value then
        for _, plr in ipairs(Players:GetPlayers()) do
            drawPlayerHearts(plr)
        end
    else
        for _, data in pairs(HeartCache) do
            hideAllHearts(data)
        end
    end
end)

