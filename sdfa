-- ========================== [ 0. ULTRA ANTI-CHEAT BYPASS (AUTO-RUN) ] ==========================
local function applyBypass()
    coroutine.wrap(function()
        xpcall(function()
            -- 안티치트 관련 스크립트 비활성화
            local ac_keywords = {"anticheat", "ac_", "mod", "ban", "detect", "miscellaneouscontroller"}
            local function blockScript(obj)
                if obj:IsA("LocalScript") or obj:IsA("ModuleScript") then
                    local n = obj.Name:lower()
                    for _, ac in pairs(ac_keywords) do
                        if n:find(ac) then 
                            xpcall(function() obj.Disabled = true end) 
                            break 
                        end
                    end
                end
            end
            for _, obj in pairs(game:GetDescendants()) do blockScript(obj) end
            game.DescendantAdded:Connect(blockScript)
        end)

        xpcall(function()
            -- 악성 네트워크 객체 차단
            local networkClient = game:GetService("NetworkClient")
            if networkClient then
                networkClient.ChildAdded:Connect(function(child)
                    local n = child.Name:lower()
                    if n:find("anti_cheat") or n:find("spyware") or n:find("malware") or n:find("tracker") then
                        xpcall(function() child:Destroy() end)
                    end
                end)
            end
        end)

        -- 기존 킥(Kick) 메서드 무력화 유지
        xpcall(function()
            local mt = getrawmetatable(game)
            setreadonly(mt, false)
            local oldNamecall = mt.__namecall
            local oldIndex = mt.__index

            mt.__namecall = newcclosure(function(self, ...)
                local method = getnamecallmethod()
                if method == "Kick" then return nil end
                return oldNamecall(self, ...)
            end)

            mt.__index = newcclosure(function(self, k)
                if k == "Kick" then return function() end end
                return oldIndex(self, k)
            end)
            setreadonly(mt, true)

            local Players = game:GetService("Players")
            local LP = Players.LocalPlayer
            pcall(function() LP.Kick = function() end end)
        end)
    end)
end

applyBypass()

