local function scaleModelProper(model, multiplier)
    if not model:IsA("Model") then return end
    if not model.Name:match("^" .. LP.Name .. " %-% ") then return end
    
    if multiplier == 1.0 then
        if model:GetAttribute("Scaled") then
            model:SetAttribute("Scaled", nil)
            for _, part in ipairs(model:GetDescendants()) do
                if part:IsA("BasePart") then
                    local origSize = part:GetAttribute("OrigSize")
                    local origCF = part:GetAttribute("OrigCF")
                    if origSize and origCF then
                        part.Size = origSize
                        part.CFrame = origCF
                    end
                end
            end
        end
        return
    end

    if model:GetAttribute("Scaled") then return end
    model:SetAttribute("Scaled", true)

    local pivot = model:GetPivot()
    for _, part in ipairs(model:GetDescendants()) do
        if part:IsA("BasePart") then
            local origSize = part:GetAttribute("OrigSize") or part.Size
            local origCF = part:GetAttribute("OrigCF") or part.CFrame

            part:SetAttribute("OrigSize", origSize)
            part:SetAttribute("OrigCF", origCF)

            local relative = pivot:ToObjectSpace(origCF)
            part.Size = origSize * multiplier
            part.CFrame = pivot * CFrame.new(relative.Position * multiplier) * (relative - relative.Position)
        end
    end
end

local function hookVMFolder(folder)
    if not folder then return end
    for _, v in ipairs(folder:GetChildren()) do
        scaleModelProper(v, Options.BigViewModel.Value)
    end
end

