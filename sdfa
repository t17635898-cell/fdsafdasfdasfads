    {0,0,0,4,2,4,0,0,0},
    {0,0,0,0,4,0,0,0,0}
}

local heartColors = {
    red = Color3.fromRGB(255,19,19),
    highlight = Color3.fromRGB(255,200,200),
    dark = Color3.fromRGB(187,19,19),
    grey = Color3.fromRGB(120,120,120),
    greyDark = Color3.fromRGB(80,80,80),
    border = Color3.fromRGB(0,0,0)
}

local heartPixels = {}
local heartLookup = {}
for y, row in ipairs(heartData) do
    for x, val in ipairs(row) do
        if val ~= 0 then
            local px, py = x-1, y-1
            table.insert(heartPixels, {x = px, y = py, type = val})
            heartLookup[px..":"..py] = true
        end
    end
end

local heartBorders = {}
local dirs = {{1,0},{-1,0},{0,1},{0,-1}}
for _, p in ipairs(heartPixels) do
    for _, d in ipairs(dirs) do
        local nx, ny = p.x + d[1], p.y + d[2]
        if not heartLookup[nx..":"..ny] then
            table.insert(heartBorders, {x = nx, y = ny})
        end
    end
end

local function getHeartData(name)
    if not HeartCache[name] then
        local t = {}
        for i = 1, 2000 do
            local s = Drawing.new("Square")
            s.Filled = true
            s.Transparency = 1
            t[i] = s
        end
        HeartCache[name] = t
    end
    return HeartCache[name]
end

local function hideAllHearts(data)
    for _, v in ipairs(data) do v.Visible = false end
end

local function drawHeartObj(data, index, x, y, px, isGrey, half)
    for _, p in ipairs(heartPixels) do
        if half and p.x >= 4 then continue end
        local sq = data[index]; index += 1
        sq.Size = Vector2.new(px, px)
        sq.Position = Vector2.new(x + p.x*px, y + p.y*px)
        local col
        if p.type == 2 then col = isGrey and heartColors.grey or heartColors.red
        elseif p.type == 3 then col = isGrey and heartColors.grey or heartColors.highlight
        elseif p.type == 4 then col = isGrey and heartColors.greyDark or heartColors.dark end
        sq.Color = col
        sq.Visible = true
    end
    for _, p in ipairs(heartBorders) do
        if half and p.x >= 4 then continue end
        local sq = data[index]; index += 1
        sq.Size = Vector2.new(px, px)
        sq.Position = Vector2.new(x + p.x*px, y + p.y*px)
        sq.Color = heartColors.border
        sq.Visible = true
    end
    return index
end

local function drawPlayerHearts(plr)
    if plr == LP then return end
    -- 아군/적군 가리지 않고 모두 표시 (팀체크 무시)

    local data = getHeartData(plr.Name)
    local char = plr.Character
    local myChar = LP.Character
    if not char or not myChar then hideAllHearts(data); return end

    local root = char:FindFirstChild("HumanoidRootPart")
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not root or not myRoot then hideAllHearts(data); return end

    local dx = root.Position.X - myRoot.Position.X
    local dy = root.Position.Y - myRoot.Position.Y
    local dz = root.Position.Z - myRoot.Position.Z
    local distSq = dx*dx + dy*dy + dz*dz
    if distSq > (150 * 150) then hideAllHearts(data); return end

    local hum = char:FindFirstChildOfClass("Humanoid")
    local head = char:FindFirstChild("Head")
    if not hum or not head then hideAllHearts(data); return end

    local pos, onScreen = Workspace.CurrentCamera:WorldToViewportPoint(head.Position + Vector3.new(0, 3, 0))
    if not onScreen then hideAllHearts(data); return end

    local px = 2
    local spacing = 4
    local width = 9 * px
    local hp = hum.Health
    local max = hum.MaxHealth
    local hearts = (hp / max) * 20
    local full = math.floor(hearts / 2)
    local half = hearts % 2 >= 1

    local startX = pos.X - ((width + spacing) * 10) / 2
    local startY = pos.Y
    local index = 1

    for h = 1, 10 do
        local hx = startX + (h - 1) * (width + spacing)
        if h <= full then
            index = drawHeartObj(data, index, hx, startY, px, false, false)
        elseif h == full + 1 and half then
            index = drawHeartObj(data, index, hx, startY, px, true, false)
            index = drawHeartObj(data, index, hx, startY, px, false, true)
        else
            index = drawHeartObj(data, index, hx, startY, px, true, false)
        end
    end

    for i = index, #data do data[i].Visible = false end
end

