        hum.HealthChanged:Connect(function(newHealth)
            if Toggles.DamageNotifier and Toggles.DamageNotifier.Value and newHealth < lastHealth then
                if recentAttack.target == player and (tick() - recentAttack.time) <= 0.5 then
