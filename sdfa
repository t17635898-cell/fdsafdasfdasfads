        local rootPart = character:FindFirstChild('HumanoidRootPart')
        local head = character:FindFirstChild('Head')
        local humanoid = character:FindFirstChildWhichIsA('Humanoid')
        return rootPart and head and humanoid and humanoid.Health > 0 or false 
    end 
    function TargetController:GetClosestTarget() 
        local closestTarget = nil; local maxDistance = math.huge 
        local mousePos = UserInputService:GetMouseLocation()
        for _, player in next, Players:GetPlayers() do 
            if player == LP then continue end 
            if isSameTeam(player) then continue end 
            local character = player.Character 
            if not character or not self:IsValidTarget(character) then continue end 
            local rootPart = character.HumanoidRootPart 
            local screenPos, onScreen = Workspace.CurrentCamera:WorldToViewportPoint(rootPart.Position)
            if not onScreen then continue end 
            local rootPos = Vector2.new(screenPos.X, screenPos.Y)
            local targetDist = (mousePos - rootPos).magnitude 
            if targetDist < maxDistance then maxDistance = targetDist; closestTarget = player end 
        end 
        return closestTarget
    end 
    TargetController:init()
end 

local AntiWeapon = {}
function AntiWeapon:GetWeaponName(targetPlayer)
    if not targetPlayer then return "" end
    local viewModels = Workspace:FindFirstChild("ViewModels")
    if not viewModels then return "" end
    for _, model in ipairs(viewModels:GetChildren()) do
        if model:IsA("Model") then
            local separator = model.Name:find(" - ", 1, true)
            if separator and model.Name:sub(1, separator - 1) == targetPlayer.Name then
                return model.Name:sub(separator + 3):lower()
            end
        end
    end
    return ""
end
function AntiWeapon:ShouldAttack(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return false end
    local hum = targetPlayer.Character:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    local weaponName = self:GetWeaponName(targetPlayer)
    if weaponName:find("katana", 1, true) or weaponName:find("riot", 1, true) or weaponName:find("shield", 1, true) then return false end
    return true
end

